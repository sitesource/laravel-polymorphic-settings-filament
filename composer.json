{
    "name": "sitesource/laravel-polymorphic-settings-filament",
    "description": "Filament integration for sitesource/laravel-polymorphic-settings — base page class and trait that auto-bind settings to Filament forms.",
    "keywords": [
        "laravel",
        "filament",
        "filamentphp",
        "settings",
        "laravel-settings",
        "polymorphic-settings",
        "polymorphic",
        "configuration",
        "admin"
    ],
    "homepage": "https://github.com/sitesource/laravel-polymorphic-settings-filament",
    "license": "MIT",
    "authors": [
        {
            "name": "Nathan Call",
            "email": "info@site-source.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2||^8.3||^8.4||^8.5",
        "spatie/laravel-package-tools": "^1.16",
        "illuminate/contracts": "^12.0||^13.0",
        "filament/filament": "^5.6",
        "sitesource/laravel-polymorphic-settings": "^0.1.2"
    },
    "require-dev": {
        "laravel/pint": "^1.14",
        "nunomaduro/collision": "^8.8",
        "larastan/larastan": "^3.0",
        "orchestra/testbench": "^10.0.0||^11.0.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-arch": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "pestphp/pest-plugin-livewire": "^4.0",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "SiteSource\\PolymorphicSettings\\Filament\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SiteSource\\PolymorphicSettings\\Filament\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "analyse": "@php -d memory_limit=1G vendor/bin/phpstan analyse",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "SiteSource\\PolymorphicSettings\\Filament\\FilamentSettingsServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
